# ── Training data (images / CSVs — too large / irrelevant for repo) ──────────
data/
*.csv
*.jpg
*.jpeg
*.png
*.gif
*.bmp

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env

# ── MediaPipe / ML model artifacts (too large for git) ───────────────────────
# Keep the models/ directory itself but ignore large binary model files
# if you want to track the .task file, remove the next two lines
*.task
*.tflite
*.h5
*.pkl
*.pb
*.onnx

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
tmp/
temp/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

